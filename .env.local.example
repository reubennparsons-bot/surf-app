# Copy this file to .env.local and fill in real values.
# .env.local is gitignored.

# Anthropic API key — used by lib/narration/client.ts to call Claude Sonnet 4.6.
# Create one at https://console.anthropic.com/
ANTHROPIC_API_KEY= 

# Optional: override the default narration model.
# Defaults to claude-sonnet-4-6 if unset.
# ANTHROPIC_MODEL=claude-sonnet-4-6
